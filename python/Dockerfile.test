# Dockerfile for running Python integration tests locally.
# Replicates the CI pipeline (python.yml).
# Base image (Rust + protoc + python3 + Valkey + pre-compiled deps) via docker-bake.test.hcl.
#
# Usage (from repo root):
#   docker buildx bake python-test --load
#   docker run --rm python-test
#   docker run --rm -e TEST_ARGS="-k test_ping" python-test

FROM base

ENV CARGO_TARGET_DIR=/app/target

# pip needs these for building wheels (maturin, cffi, etc.)
RUN apt-get update && \
    apt-get install -y --no-install-recommends python3-dev python3-venv pip && \
    rm -rf /var/lib/apt/lists/*

# L1: Python dependency cache
COPY python/dev_requirements.txt python/
RUN python3 -m venv python/.env && \
    python/.env/bin/pip install --no-cache-dir -r python/dev_requirements.txt

# L2: Full source → lint → build
COPY . .

# --- Rust lint (matches CI: .github/workflows/lint-rust/action.yml) ---
RUN cd python/glide-async && cargo fmt --all -- --check
RUN cd python/glide-async && cargo clippy --all-features --all-targets -- -D warnings
RUN cd python/glide-async && cargo clippy --all-targets -- -D warnings
RUN cd python/glide-async && RUSTDOCFLAGS="-Dwarnings" cargo doc --no-deps --document-private-items

RUN cd python && python3 dev.py build --no-cache

# --- Python lint (matches CI: python.yml lint job) ---
RUN cd python && python3 dev.py lint --check

# Optional: TEST_ARGS to pass extra args to pytest (e.g. "-k test_ping").
CMD ["bash", "-c", "\
  cd python && \
  python3 dev.py test --args --async-backend=asyncio \
    --html=pytest_report.html --self-contained-html \
    $TEST_ARGS \
"]
