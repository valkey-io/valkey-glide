FROM public.ecr.aws/amazoncorretto/amazoncorretto:21

# Install iproute2 for tc (network chaos) and procps for jstack
RUN yum install -y iproute iproute-tc procps-ng net-tools iptables && yum clean all

WORKDIR /app
COPY build/libs/glide-repro.jar /app/app.jar

# Default env vars
ENV ROLE=worker
ENV CLUSTER_ENDPOINT=clustercfg.testing-cluster.ey5v7d.use2.cache.amazonaws.com
ENV CLUSTER_PORT=6379
ENV NUM_THREADS=60
ENV MODE=sync
ENV LISTEN_PORT=9001
ENV POD_ID=worker-0
ENV HEARTBEAT_DIR=/shared/heartbeats
ENV RESULTS_DIR=/shared/results
ENV GLIDE_TOKIO_WORKER_THREADS=1

# JVM options for visibility
ENV JAVA_OPTS="-Xmx1536m -XX:+PrintGCDetails -XX:+UseG1GC -Dlog4j2.formatMsgNoLookups=true"

ENTRYPOINT ["sh", "-c", "java $JAVA_OPTS -jar /app/app.jar"]
