# Dockerfile for running FFI (Rust) tests locally.
# Base image (Rust + protoc + python3 + Valkey) provided via docker-bake.test.hcl.
#
# Usage (from repo root):
#   docker buildx bake ffi-test --load
#   docker run --rm ffi-test
#   docker run --rm -e TEST_ARGS="-- test_name_filter" ffi-test

FROM base

# L1: Rust dependency cache — copy manifests first, then fetch
COPY ffi/Cargo.toml ffi/
COPY glide-core/Cargo.toml glide-core/
COPY glide-core/redis-rs/Cargo.toml glide-core/redis-rs/
COPY glide-core/redis-rs/redis/Cargo.toml glide-core/redis-rs/redis/
COPY glide-core/telemetry/Cargo.toml glide-core/telemetry/
COPY logger_core/Cargo.toml logger_core/
RUN mkdir -p ffi/src && echo "" > ffi/src/lib.rs && \
    mkdir -p glide-core/src && echo "" > glide-core/src/lib.rs && \
    mkdir -p glide-core/benches && \
    touch glide-core/benches/connections_benchmark.rs \
          glide-core/benches/memory_benchmark.rs \
          glide-core/benches/rotating_buffer_benchmark.rs && \
    mkdir -p glide-core/redis-rs/redis/src && echo "" > glide-core/redis-rs/redis/src/lib.rs && \
    mkdir -p glide-core/telemetry/src && echo "" > glide-core/telemetry/src/lib.rs && \
    mkdir -p logger_core/src && echo "" > logger_core/src/lib.rs
RUN cd ffi && cargo fetch

# L2: Full source → build test binaries
COPY . .
RUN cd ffi && cargo test --no-run

# Optional: TEST_ARGS for extra cargo test flags.
ENV CARGO_TERM_COLOR=always
CMD ["bash", "-c", "cd ffi && cargo test $TEST_ARGS"]
